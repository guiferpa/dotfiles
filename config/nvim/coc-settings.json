{
  "coc.preferences.formatOnSave": true,
  "languageserver": {
    "aurora": {
      "host": "127.0.0.1",
      "filetypes": ["aurora"],
      "port": 1337
    },
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.work", "go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"],
      "initializationOptions": {
        "usePlaceholders": true
      }
    }
  },
  "snippets.ultisnips.pythonPrompt": false
}
